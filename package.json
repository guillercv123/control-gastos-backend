{
  "name": "control-gastos-backend",
  "version": "0.2.0",
  "description": "Backend Node.js + TypeScript sobre AWS para control de gastos hormiga (Yape/Plin/efectivo).",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "sam build",
    "deploy": "sam deploy",
    "deploy:guided": "sam deploy --guided",
    "logs": "sam logs --stack-name control-gastos-backend --tail"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.620.0",
    "@aws-sdk/lib-dynamodb": "^3.620.0",
    "esbuild": "^0.20.2",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.137",
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5"
  }
}
